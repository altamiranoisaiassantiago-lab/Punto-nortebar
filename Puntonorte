<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurante Boliviano</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; background-color: #fff; color: #333; }
        h1 { text-align: center; }
        ul { list-style: none; padding: 0; }
        li { margin: 10px 0; }
        form { max-width: 400px; margin: 20px auto; }
        label { display: block; margin-top: 10px; }
        select, input[type="submit"] { width: 100%; padding: 10px; margin-top: 5px; }
    </style>
</head>
<body>
    <h1>Menú del Restaurante Boliviano</h1>
    <ul>
        <li>Salteña - $250</li>
        <li>Silpancho - $700</li>
        <li>Pique a lo Macho - $850</li>
        <li>Sopa de Mani - $400</li>
    </ul>
    <h2>Reserva tu mesa</h2>
    <form>
        <label for="mesa">Elige una mesa:</label>
        <select id="mesa" name="mesa">
            <option value="1">Mesa 1</option>
            <option value="2">Mesa 2</option>
            <option value="3">Mesa 3</option>
            <option value="5">Mesa 5</option>
            <option value="7">Mesa 7</option>
            <option value="8">Mesa 8</option>
            <option value="9">Mesa 9</option>
            <option value="10">Mesa 10</option>
            <option value="11">Mesa 11</option>
            <option value="12">Mesa 12</option>
            <option value="barraA">Barra A</option>
            <option value="barraB">Barra B</option>
        </select>
        <input type="submit" value="Reservar">
    </form>
</body>
</html>
